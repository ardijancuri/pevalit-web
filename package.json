{
  "name": "pevalit-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src next.config.mjs eslint.config.mjs postcss.config.mjs --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "sync:assets": "node scripts/sync-assets.mjs",
    "sync:assets:dry": "node scripts/sync-assets.mjs --dry-run",
    "sync:products": "node scripts/sync-products.mjs",
    "sync:products:dry": "node scripts/sync-products.mjs --dry-run",
    "extract:catalog": "python scripts/extract-catalog-content.py"
  },
  "dependencies": {
    "next": "16.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "4.1.2",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.0.9",
    "@types/node": "22.13.4",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "9.20.1",
    "eslint-config-next": "16.0.1",
    "tailwindcss": "4.0.9",
    "typescript": "5.7.3"
  }
}
