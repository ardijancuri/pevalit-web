{
  "name": "pevalit-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0 <23"
  },
  "scripts": {
    "dev": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=true BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next dev",
    "build": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=true BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next build",
    "start": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=true BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next start",
    "lint": "eslint src next.config.mjs eslint.config.mjs postcss.config.mjs --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^16.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "resend": "4.1.2",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.0.9",
    "@types/node": "22.13.4",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "cross-env": "10.1.0",
    "eslint": "9.20.1",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "4.0.9",
    "typescript": "5.7.3"
  }
}
